#include <string>
#include <algorithm>

class Solution {
public:
    std::string reverseWords(std::string s) {
        std::reverse(s.begin(), s.end());
        
        int n = s.length();
        int idx = 0;
        
        for (int start = 0; start < n; ++start) {
            if (s[start] != ' ') {
                if (idx != 0) s[idx++] = ' ';
                
                int end = start;
                while (end < n && s[end] != ' ') {
                    s[idx++] = s[end++];
                }
                
                std::reverse(s.begin() + idx - (end - start), s.begin() + idx);
                start = end;
            }
        }
        
        s.erase(s.begin() + idx, s.end());
        return s;
    }
};
