
class Solution {
public:
    void flatten(TreeNode* root) {
        
        while(root){
            if(root->left){

                TreeNode* pred = root->left;
                while(pred->right) pred = pred->right;

               
                pred->right = root->right;

                
                root->right = root->left;

              
                root->left = NULL;
            }

            
            root = root->right;
        }
    }
};
