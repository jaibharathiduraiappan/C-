#include <vector>
#include <unordered_map>
#include <algorithm>
#include <numeric>

class Solution {
public:
    int maxPoints(std::vector<std::vector<int>>& points) {
        int n = points.size();
        if (n <= 2) return n;
        
        int max_pts = 0;
        
        for (int i = 0; i < n; ++i) {
            std::unordered_map<std::string, int> slope_map;
            int duplicate = 1;
            int current_max = 0;
            
            for (int j = i + 1; j < n; ++j) {
                int dx = points[j][0] - points[i][0];
                int dy = points[j][1] - points[i][1];
                
                if (dx == 0 && dy == 0) {
                    duplicate++;
                    continue;
                }
                
                int g = std::gcd(dx, dy);
                dx /= g;
                dy /= g;
                
                if (dx < 0 || (dx == 0 && dy < 0)) {
                    dx = -dx;
                    dy = -dy;
                }
                
                std::string slope = std::to_string(dx) + "_" + std::to_string(dy);
                slope_map[slope]++;
                current_max = std::max(current_max, slope_map[slope]);
            }
            
            max_pts = std::max(max_pts, current_max + duplicate);
        }
        
        return max_pts;
    }
};
